# ===========================================
# Discord Bot Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Discord ---
DISCORD_TOKEN=

# --- LLM ---
LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic

# OpenAI-compatible
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# --- Database ---
DATABASE_URL=sqlite:///database/bot.db
